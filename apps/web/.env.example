# Frontend env. Copy to apps/web/.env (gitignored).

# Empty = same-origin. In dev vite proxies /api/* → 127.0.0.1:3025 automatically.
# In prod nginx proxies /api/* → localhost:3025 (vedi deploy/nginx-cozza-ai.conf).
VITE_API_BASE_URL=

# ElevenLabs voice id (italian). Pick from https://elevenlabs.io/voices
VITE_ELEVENLABS_VOICE_ID=

# Default chat model on first load.
# Switched to gpt-4o-mini while Anthropic billing/credit issue is being resolved.
# Revert to claude-haiku-4-5 once /api/chat/anthropic returns 200.
VITE_DEFAULT_MODEL=gpt-4o-mini

# Build commit (auto-set by deploy.sh)
VITE_BUILD_COMMIT=local
