# cozza-ai API — env file. Copy to apps/api/.env (gitignored).

# Listen port (PM2 picks this up; nginx proxies to it)
PORT=3025
HOST=127.0.0.1

# AI provider keys (server-side only, NEVER commit)
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-proj-...
ELEVENLABS_API_KEY=sk_...

# CORS allowlist (comma separated, no spaces)
ALLOWED_ORIGINS=http://localhost:5173,https://cozza-ai.vibecanyon.com

# Rate limit (requests / IP / minute)
RATE_LIMIT_PER_MIN=30

# Build commit (auto-set by deploy script)
COMMIT_SHA=local
