{
  "name": "cockpit-bus",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --inspect=9230 src/index.ts",
    "build": "rimraf dist && tsc && tsc-alias --resolve-full-paths",
