# cockpit-bus environment

# Listening port (the reverse SSH tunnel binds VPS:3031 → here)
PORT=3030

# JWT secret for cockpit auth tokens (different from cozza-ai admin!)
COCKPIT_JWT_SECRET=replace-with-32+-char-random

# Allowed origins for CORS / WS
COCKPIT_ALLOWED_ORIGINS=https://cozza-ai.vibecanyon.com,http://localhost:5174,http://localhost:5175

# Path to SQLite history db (relative to repo or absolute)
COCKPIT_DB_PATH=./cockpit.db

# Path to memory/all-projects.md (used by health adapter to know what to ping)
COCKPIT_PROJECTS_CATALOG=C:/Users/lucap/.claude/projects/c--work-Cozza/memory/all-projects.md

# SSH details for PM2 logs / VPS metrics adapter
COCKPIT_VPS_HOST=188.213.170.214
COCKPIT_VPS_USER=root
COCKPIT_VPS_KEY=C:/Users/lucap/.ssh/aruba_vps

# Health poll interval in seconds
COCKPIT_HEALTH_POLL_SECONDS=30

# Enable input plane (mouse/keyboard remote control). Default: false (opt-in)
COCKPIT_INPUT_ENABLED=false

# Master kill code (the killswitch endpoint requires this in headers as extra guard)
COCKPIT_KILL_CODE=replace-me
